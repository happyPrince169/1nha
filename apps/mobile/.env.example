# ---------------------------------------------------------------------------
# 1nha mobile — copy to `.env` and fill in. NEVER commit `.env`.
#
# Only PUBLIC values live here. The mobile app uses the Supabase ANON key for
# Auth ONLY and talks to the data layer exclusively through the Next.js API.
# There is NO service-role key in the mobile app, ever.
# ---------------------------------------------------------------------------

# Base URL of the deployed (or local) Next.js web app that hosts the /api routes.
# Local web dev on a physical device: use your machine's LAN IP, not localhost.
#   Local (simulator):  http://localhost:3000
#   Local (device):     http://192.168.1.x:3000
#   Production:         https://your-app.vercel.app
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Supabase project — same values as the web app's NEXT_PUBLIC_SUPABASE_* (the
# anon key is public by design and RLS-scoped).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
